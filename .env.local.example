# Groq API key — used by the recipe agent (Llama 3.3 70B).
# Free tier is enough. Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# GitHub PAT — authed GitHub API calls (tree + file contents).
# Anonymous GitHub gives you 60 req/hour. A PAT gives you 5,000.
# If you have `gh` installed: `gh auth token` prints a valid token.
GITHUB_TOKEN=ghp_your_token_here

# Optional — override the Groq model. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=moonshotai/kimi-k2-instruct

# Optional — run the full flow without real Locus checkout or deployment.
# Useful for theater/UI work when you don't want to burn USDC.
# LOCUS_MOCK=1
